    "             style=\"c0.16c\", fill=\"royalblue\", pen=\"0.2p,black\")\n",
    "if len(near) > 0:\n",
    "    fig.plot(x=near[\"paleo_lon\"], y=near[\"paleo_lat\"],\n",
    "             style=\"c0.16c\", fill=\"red2\", pen=\"0.2p,black\")\n",
    "fig.text(text=f\"{RECONSTRUCTION_TIME:.0f} Ma  ({MODEL_NAME})\",\n",
