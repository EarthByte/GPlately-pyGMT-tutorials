    "                           pen=\"0.6p,gray50\")\n",
    "(tl, tr) = gplot.get_subduction_direction()\n",
    "engine.plot_subduction_zones(fig, tl, tr, color=\"blue\")\n",
    "\n",
    "near = sub[sub[\"dist_to_subduction_km\"] < 700]\n",
    "far  = sub[sub[\"dist_to_subduction_km\"] >= 700]\n",
    "if len(far) > 0:\n",
